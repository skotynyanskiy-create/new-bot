# SECURITY WARNING: NON CONDIVIDERE QUESTO FILE.
# Copia questo file come .env e inserisci le tue chiavi reali.
# Aggiungi .env al .gitignore e non committare mai le chiavi!

# =====================================================================
# Bybit Linear Futures — EXCHANGE PRINCIPALE (consigliato per EU/Italia)
# Crea le chiavi su: https://www.bybit.com/app/user/api-management
# Permessi necessari: "Derivatives" (read + trade). NON abilitare prelievi!
# =====================================================================
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_SECRET_KEY=your_bybit_secret_key_here

# =====================================================================
# Bybit TESTNET (conto demo — fondi virtuali, zero rischi)
# 1. Vai su: https://testnet.bybit.com
# 2. Registrati → genera API Key
# 3. In config.yaml: live_trading_enabled: true  + testnet: true
# =====================================================================
BYBIT_TESTNET_API_KEY=
BYBIT_TESTNET_SECRET_KEY=

# =====================================================================
# Binance Futures (alternativa — imposta exchange: "binance" in config.yaml)
# =====================================================================
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET_KEY=

# =====================================================================
# Telegram Notifications (opzionale)
# 1. Crea bot con @BotFather → ottieni TOKEN
# 2. Avvia chat col bot → apri api.telegram.org/bot<TOKEN>/getUpdates
#    → cerca "id" dentro "chat" → è il CHAT_ID
# Lascia vuoti per disabilitare le notifiche.
# =====================================================================
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# =====================================================================
# Anthropic Claude API (opzionale — per future integrazioni AI)
# =====================================================================
ANTHROPIC_API_KEY=
